  <execution class="org.jenkinsci.plugins.workflow.cps.CpsFlowExecution">
    <result>SUCCESS</result>
    <script>pipeline {
    agent any

    environment {
        // ID of credentials created in Jenkins
        DOCKER_HUB_CRED = &apos;dockerhub-cred&apos; 
        // MAKE SURE YOU REPLACE &apos;yourdockerhubusername&apos; with your actual username
        IMAGE_NAME = &apos;angelkwatra/flask-cicd-app&apos;
        IMAGE_TAG = &quot;${env.BUILD_NUMBER}&quot;
    }

    stages {
        stage(&apos;Clone Repository&apos;) {
            steps {
                echo &apos;Cloning from GitHub...&apos;
                checkout scm
            }
        }
        
        stage(&apos;Build Docker Image&apos;) {
            steps {
                echo &apos;Building Docker Image...&apos;
                script {
                    dockImage = docker.build(&quot;${IMAGE_NAME}:${IMAGE_TAG}&quot;, &quot;LAB/EXPERIMENT7/flask-app&quot;)
                }
            }
        }
        
        stage(&apos;Push to Docker Hub&apos;) {
            steps {
                echo &apos;Authenticating and Pushing Image to Docker Hub...&apos;
                script {
                    docker.withRegistry(&apos;https://index.docker.io/v1/&apos;, DOCKER_HUB_CRED) {
                        dockImage.push()
                        dockImage.push(&apos;latest&apos;)
                    }
                }
            }
        }
    }
}
</script>
